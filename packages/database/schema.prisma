generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid()) @map("id")
  email            String    @unique @map("correo")
  phone            String    @unique @map("telefono")
  name             String    @map("nombre")
  passwordHash     String    @map("contrasena_hash")
  rut              String?   @unique @map("rut")
  birthDate        DateTime? @map("fecha_nacimiento")
  address          String?   @map("direccion")
  idFrontUrl       String?   @map("url_carnet_frente")
  idBackUrl        String?   @map("url_carnet_dorso")
  backgroundDocUrl String?   @map("url_certificado_antecedentes")
  isVerified       Boolean   @default(false) @map("esta_verificado")
  emailVerified    Boolean   @default(true) @map("correo_verificado")
  emailCode        String?   @map("codigo_correo")
  resetCode        String?   @map("codigo_restablecer")
  resetCodeExpires DateTime? @map("expiracion_codigo_restablecer")
  paymentMethod    String?   @map("metodo_pago")
  mpCardToken      String?   @map("token_tarjeta_mp")
  role             String    @default("passenger") @map("rol")
  createdAt        DateTime  @default(now()) @map("fecha_creacion")
  updatedAt        DateTime  @updatedAt @map("fecha_actualizacion")
  selfieUrl        String?   @map("url_selfie")
  ratings          Rating[]  @relation("PassengerRatings")
  trips            Trip[]    @relation("PassengerTrips")
  fcmToken         String?   @map("token_fcm")
  tokenVersion     Int       @default(0) @map("version_token")
  isDeleted        Boolean   @default(false) @map("esta_eliminado")
  status           String    @default("active") @map("estado")
  cancellationCount Int      @default(0) @map("cantidad_cancelaciones")

  @@map("usuarios")
}

model Driver {
  id                  String    @id @default(cuid()) @map("id")
  email               String    @unique @map("correo")
  phone               String    @unique @map("telefono")
  name                String    @map("nombre")
  passwordHash        String    @map("contrasena_hash")
  rut                 String    @unique @map("rut")
  birthDate           DateTime  @map("fecha_nacimiento")
  address             String    @map("direccion")
  idFrontUrl          String    @map("url_carnet_frente")
  idBackUrl           String    @map("url_carnet_dorso")
  backgroundDocUrl    String?   @map("url_certificado_antecedentes")
  selfieUrl           String?   @map("url_selfie")
  licenseNumber       String    @map("numero_licencia")
  licenseUrl          String    @map("url_licencia_frente")
  licenseBackUrl      String    @default("") @map("url_licencia_dorso")
  vehicleBrand        String    @map("marca_vehiculo")
  vehicleModel        String    @map("modelo_vehiculo")
  vehicleYear         Int       @map("anio_vehiculo")
  vehiclePlate        String    @unique @map("patente_vehiculo")
  vehicleColor        String    @default("") @map("color_vehiculo")
  vehiclePhotoUrl     String    @map("url_foto_vehiculo")
  tagNumber           String    @map("numero_tag")
  status              String    @default("pending") @map("estado")
  membershipPaid      Boolean   @default(false) @map("membresia_pagada")
  membershipPlan      String    @default("BLACK") @map("plan_membresia")
  membershipProgress  Int       @default(0) @map("progreso_membresia")
  membershipGoal      Int       @default(150000) @map("meta_membresia")
  dailyCashTripsCount Int       @default(0) @map("viajes_efectivo_diarios")
  comfortDebt         Int       @default(0) @map("deuda_comfort")
  comfortLastPaidAt   DateTime? @map("ultimo_pago_comfort")
  membershipWeekStart DateTime? @map("inicio_semana_membresia")
  membershipDate      DateTime? @map("fecha_membresia")
  mpSubscriptionId    String?   @map("id_suscripcion_mp")
  membershipExpiresAt DateTime? @map("expiracion_membresia")
  comfortReceiptUrl   String?   @map("url_comprobante_comfort")
  walletBalance       Int       @default(0) @map("saldo_billetera")
  adminNotes          String?   @map("notas_administrador")
  mercadoPagoLink     String?   @map("enlace_mercado_pago") // Link de pago directo (mpago.li/...)
  isOnline            Boolean   @default(false) @map("esta_en_linea")
  lastLat             Float?    @map("ultima_latitud")
  lastLng             Float?    @map("ultima_longitud")
  lastSeen            DateTime? @map("ultima_conexion")
  totalRating         Float     @default(0) @map("calificacion_total")
  totalTrips          Int       @default(0) @map("viajes_totales")
  topQualities        String[]  @default([]) @map("mejores_cualidades")
  isTrial             Boolean   @default(false) @map("es_prueba")
  nextDiscount        Int       @default(0) @map("siguiente_descuento")
  emailVerified       Boolean   @default(true) @map("correo_verificado")
  emailCode           String?   @map("codigo_correo")
  resetCode           String?   @map("codigo_restablecer")
  resetCodeExpires    DateTime? @map("expiracion_codigo_restablecer")
  createdAt           DateTime  @default(now()) @map("fecha_creacion")
  updatedAt           DateTime  @updatedAt @map("fecha_actualizacion")
  ratings             Rating[]  @relation("DriverRatings")
  trips               Trip[]    @relation("DriverTrips")
  fcmToken            String?   @map("token_fcm")
  giftDaysPending     Int       @default(0) @map("dias_regalo_pendientes")
  tokenVersion        Int       @default(0) @map("version_token")
  isDeleted           Boolean   @default(false) @map("esta_eliminado")
  cancellationCount   Int       @default(0) @map("cantidad_cancelaciones")

  // Fim Finanzas Config
  fuelEfficiency      Float?    @default(12.0) @map("rendimiento_combustible")
  fuelPrice           Int?      @default(1300) @map("precio_combustible")
  netIncomeGoal       Int?      @default(1000000) @map("meta_ingreso_neto")

  @@map("conductores")
}

model Trip {
  id              String         @id @default(cuid()) @map("id")
  passengerId     String         @map("id_pasajero")
  driverId        String?        @map("id_conductor")
  originLat       Float          @map("latitud_origen")
  originLng       Float          @map("longitud_origen")
  originAddress   String         @map("direccion_origen")
  destLat         Float          @map("latitud_destino")
  destLng         Float          @map("longitud_destino")
  destAddress     String         @map("direccion_destino")
  stops           Json?          @map("paradas")
  distanceKm      Float          @map("distancia_km")
  durationMin     Int            @map("duracion_min")
  estimatedPrice  Int            @map("precio_estimado")
  finalPrice      Int?           @map("precio_final")
  isDiscounted    Boolean        @default(false) @map("tiene_descuento")
  paymentMethod   String         @map("metodo_pago")
  isPaid          Boolean        @default(false) @map("esta_pagado")
  paymentStatus   String         @default("pending") @map("estado_pago")
  otpCode         String?        @map("codigo_otp")
  dropoffOtpCode  String?        @map("codigo_otp_destino") // Código que el pasajero da al conductor al bajarse
  mpPaymentId     String?        @map("id_pago_mp")
  status          String         @default("searching") @map("estado")
  passengerCount  Int            @default(1) @map("cantidad_pasajeros")
  cancelledBy     String?        @map("cancelado_por")
  cancelReason    String?        @map("motivo_cancelacion")
  requestedAt     DateTime       @default(now()) @map("fecha_solicitud")
  acceptedAt      DateTime?      @map("fecha_aceptacion")
  driverArrivedAt DateTime?      @map("fecha_llegada_conductor")
  startedAt       DateTime?      @map("fecha_inicio")
  completedAt     DateTime?      @map("fecha_fin")
  cancelledAt     DateTime?      @map("fecha_cancelacion")
  createdAt       DateTime       @default(now()) @map("fecha_creacion")
  updatedAt       DateTime       @updatedAt @map("fecha_actualizacion")
  rating          Rating?
  driver          Driver?        @relation("DriverTrips", fields: [driverId], references: [id])
  passenger       User           @relation("PassengerTrips", fields: [passengerId], references: [id])
  safetyReports   SafetyReport[]

  @@map("viajes")
}

model Rating {
  id            String   @id @default(cuid()) @map("id")
  tripId        String   @unique @map("id_viaje")
  passengerId   String   @map("id_pasajero")
  driverId      String   @map("id_conductor")
  driverScore   Int      @map("puntaje_conductor")
  driverComment String?  @map("comentario_conductor")
  tags          String[] @default([]) @map("etiquetas")
  createdAt     DateTime @default(now()) @map("fecha_creacion")
  driver        Driver   @relation("DriverRatings", fields: [driverId], references: [id])
  passenger     User     @relation("PassengerRatings", fields: [passengerId], references: [id])
  trip          Trip     @relation(fields: [tripId], references: [id])

  @@map("calificaciones")
}

model RefreshToken {
  id        String   @id @default(cuid()) @map("id")
  token     String   @unique @map("token")
  userId    String?  @map("id_usuario")
  driverId  String?  @map("id_conductor")
  expiresAt DateTime @map("fecha_expiracion")
  createdAt DateTime @default(now()) @map("fecha_creacion")

  @@map("tokens_refresco")
}

model SystemConfig {
  key       String   @id @map("clave")
  value     String   @map("valor")
  updatedAt DateTime @updatedAt @map("fecha_actualizacion")

  @@map("configuraciones_sistema")
}

model SafetyReport {
  id             String   @id @default(cuid()) @map("id")
  tripId         String   @map("id_viaje")
  reporterId     String   @map("id_reportador")
  reporterRole   String   @map("rol_reportador") // "passenger" | "driver"
  reportedUserId String   @map("id_reportado")
  reason         String   @map("motivo")
  description    String?  @map("descripcion")
  lat            Float?   @map("latitud")
  lng            Float?   @map("longitud")
  resolved       Boolean  @default(false) @map("esta_resuelto")
  adminNotes     String?  @map("notas_administrador")
  createdAt      DateTime @default(now()) @map("fecha_creacion")
  updatedAt      DateTime @updatedAt @map("fecha_actualizacion")
  trip           Trip     @relation(fields: [tripId], references: [id])

  @@map("reportes_seguridad")
}
